{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "n8n SDLC ID Mappings",
  "description": "Maps logical workflow names to their n8n IDs for dev/prod separation. Updated by reserve-workflows, push-workflow, and promote-workflow skills.",
  "type": "object",
  "required": ["workflows", "metadata"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "$comment": {
      "type": "string"
    },
    "workflows": {
      "type": "object",
      "description": "Map of logical workflow names to their dev/prod n8n IDs. Keys are PascalCase logical names (e.g., 'InvoiceAgent', 'ListInvoices').",
      "additionalProperties": {
        "$ref": "#/definitions/workflowMapping"
      }
    },
    "reservedSlots": {
      "type": "array",
      "description": "Unclaimed workflow slots. Workflows created by user in n8n but not yet assigned to a dev/prod role.",
      "items": {
        "$ref": "#/definitions/reservedSlot"
      }
    },
    "credentials": {
      "type": "object",
      "description": "Credential ID mappings between environments. Same structure as project.json credentials but tracked here for audit.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "dev": { "type": "string" },
          "prod": { "type": "string" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["projectName", "createdAt", "lastModified"],
      "properties": {
        "projectName": {
          "type": "string",
          "description": "Must match config/project.json projectName"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "lastModified": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "statusValues": {
      "type": "object",
      "description": "Reference documentation for valid status values. Not used programmatically.",
      "additionalProperties": { "type": "string" }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "workflowMapping": {
      "type": "object",
      "required": ["type", "dev", "prod"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["agent", "tool"],
          "description": "Workflow type: 'agent' for orchestrators, 'tool' for workflows called by agents"
        },
        "dev": {
          "$ref": "#/definitions/environmentSlot",
          "description": "Development environment workflow slot"
        },
        "prod": {
          "$ref": "#/definitions/environmentSlot",
          "description": "Production environment workflow slot"
        },
        "audit": {
          "$ref": "#/definitions/auditTrail"
        }
      },
      "additionalProperties": false
    },
    "environmentSlot": {
      "type": "object",
      "required": ["id", "status"],
      "properties": {
        "id": {
          "type": ["string", "null"],
          "description": "n8n workflow ID. Null means slot needs to be reserved."
        },
        "status": {
          "type": "string",
          "enum": ["active", "reserved", "needs-slot", "not-started"],
          "description": "Current state of this environment slot"
        }
      },
      "additionalProperties": false
    },
    "auditTrail": {
      "type": "object",
      "properties": {
        "lastPromoted": {
          "type": "string",
          "format": "date-time",
          "description": "When this workflow was last promoted to prod"
        },
        "promotionCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of promotions"
        },
        "lastLocalPull": {
          "type": "string",
          "format": "date-time",
          "description": "When this workflow was last pulled from n8n"
        },
        "lastPush": {
          "type": "string",
          "format": "date-time",
          "description": "When this workflow was last pushed to n8n"
        },
        "lastPushEnvironment": {
          "type": "string",
          "enum": ["dev", "prod"],
          "description": "Which environment the last push targeted"
        },
        "lastPromotionBackup": {
          "type": "string",
          "description": "File path of the last pre-promotion backup"
        },
        "lastVersionId": {
          "type": "string",
          "description": "versionId from n8n at last pull/push (for drift detection)"
        }
      },
      "additionalProperties": false
    },
    "reservedSlot": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "description": "n8n workflow ID of the unclaimed slot"
        },
        "claimedBy": {
          "type": ["string", "null"],
          "description": "Logical workflow name this slot was assigned to, or null if unclaimed"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  }
}
